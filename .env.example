# ─────────────────────────────────────────────────────────────
# .env — OMTPI HelpDesk environment variables
# NEVER commit this file. Add it to .gitignore.
# ─────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# Generate a random secret: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
SESSION_SECRET=replace_with_a_long_random_secret_string

# ── MySQL / cPanel Database ───────────────────────────────────
# In cPanel: MySQL Databases → create DB, user, and grant ALL PRIVILEGES
DB_HOST=localhost
DB_PORT=3306
DB_USER=omtpi_dbuser
DB_PASSWORD=your_database_password_here
DB_NAME=omtpi_helpdesk

# ── cPanel SMTP (Nodemailer) ──────────────────────────────────
# In cPanel: Email Accounts → your sending address
SMTP_HOST=mail.omtpi.com.ph
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=noreply@omtpi.com.ph
SMTP_PASS=your_email_account_password
SMTP_FROM="OMTPI HelpDesk <noreply@omtpi.com.ph>"

# ── cPanel API (mailing list verification) ───────────────────
# In cPanel: Manage API Tokens → Create Token → copy here
CPANEL_HOST=omtpi.com.ph
CPANEL_PORT=2083
CPANEL_USER=your_cpanel_username
CPANEL_API_TOKEN=your_cpanel_api_token_here

# ── App URL (used in email links) ─────────────────────────────
APP_URL=http://localhost:3000
